{["/_MAIN_.lua"] = {content = "--check if luacurl is installed\nlocal fs = class:getAPI('filesystem', 0)\nlocal ok, cURL = pcall(require, \"cURL\")\nif not ok then\n\9print(\"luacurl needs to be installed to install it type\\nluarocks install lua-curl\")\nend\nlocal args = {...}\nlocal lfpk = class:getAPI('lfpk', 0)\nlocal function ins(a, b, d, isLocal)\n\9if isLocal then\n\9\9local pk = lfpk:parse(a)\n\9\9for name, info in pairs((pk.info.packageDependencies or {})) do\n\9\9\9ins(name, info.verion, info.branch)\n\9\9end\n\9\9lfpk:install(pk)\n\9else\n\9\9local c = cURL.easy_init()\n\9\9local url = \"https:/raw.githubusercontent.com/\" .. a .. '/refs/heads/' .. (b or \"master\") .. \"/lfpk/lfrt/\" .. (d or \"latest\") .. \".lfpk\"\n\9\9print(url)\n\9\9c:setopt_url(url)\n\9\9local fn = \"./.tmp\" .. math.random(99999) .. \".lfpk\"\n\9\9local f = fs.open(fn, 'wb')\n\9\9c:setopt_writefunction(function(_, data)\n\9\9\9f:write(data)\n\9\9end, \"write\") -- Writes chunks directly to file disk\n\9\9local success, err = pcall(function() c:perform() end)\n\9\9c:close()\n\9\9f:flush()\n\9\9f:close()\n\9\9if success then\n\9\9\9print(\"file downloaded now installing\")\n\9\9\9local pk = lfpk:parse(fn)\n\9\9\9for name, info in pairs((pk.info.packageDependencies or {})) do\n\9\9\9\9ins(name, info.verion, info.branch)\n\9\9\9end\n\9\9\9lfpk:install(pk)\n\9\9else\n\9\9\9print(\"Error:\", err)\n\9\9end\n\9end\nend\nif args[1] == 'installLocal' then\n\9ins(args[2], args[3], args[4], true)\nelseif args[1] == 'install' then\n\9ins(args[2], args[3], args[4])\nelse\n\9print([[\nusage:\n\9* install <GithubUsername/GithubRepo> [RepoBranch (defaults to main)] [version] \n\9* installLocal <example.lfpk>\n\9]])\nend", date = 0, type = "file"}}